rules_version = '2';

// ComplaintCA — Firestore Security Rules
//
// IMPORTANT — deployment: this file is not deployed automatically. Deploy it
// yourself with `firebase deploy --only firestore:rules` (Firebase CLI,
// project ajan-d6070) or paste it into the Firebase Console under
// Firestore Database → Rules.
//
// IMPORTANT — known limitation: the app has no real user authentication tied
// to complaint ownership (see SECURITY.md). "Track by reference" / "My
// Complaints" / status updates / delete all work by the client querying for
// a ref+email match — Firestore rules can validate the *shape* of writes,
// but cannot cryptographically verify that whoever holds a document
// reference actually knows its email, because there is no signed-in
// identity to compare against. That means broad `read` access below is not
// a regression these rules introduce — it reflects the actual current
// architecture. Closing that gap for real requires migrating to Firebase
// Auth (e.g. anonymous auth + custom claims, or email-link sign-in) so
// rules can check `request.auth`, which is a larger change than a rules
// file alone.
//
// What these rules DO enforce: submissions must have the right shape and
// types (no arbitrary extra fields, no forging a "resolved" status on
// create), and updates can only ever change `status`/`timeline` — never
// re-assign a complaint's ref, email, or content after the fact. They also
// require a signed-in Firebase Auth user (any account, via the existing
// email/password or Google sign-in) to read legal-track complaints
// (isLegal==true) — this stops anonymous/public browsing of the Lawyer
// Panel feed, but it does NOT verify the signed-in account actually belongs
// to a real lawyer; that would need a separate vetting/role system and is
// out of scope here (see SECURITY.md).

service cloud.firestore {
  match /databases/{database}/documents {

    match /complaints/{complaintId} {

      // Legal-track complaints (isLegal==true) are meant to be seen only by
      // signed-in users (the Lawyer Panel), not the general public feed —
      // everything else keeps the same open read as before.
      allow read: if resource.data.get('isLegal', false) != true || request.auth != null;

      allow create: if isValidNewComplaint(request.resource.data);

      allow update: if isStatusOnlyUpdate(resource.data, request.resource.data);

      allow delete: if resource.data.keys().hasAll(['ref', 'email']);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidNewComplaint(d) {
    return d.keys().hasAll(['ref', 'title', 'desc', 'category', 'status', 'date', 'timeline'])
      && d.ref is string && d.ref.matches('^(VC|CY)-[0-9]{4}-[A-Z0-9]{6}$')
      && d.title is string && d.title.size() > 0 && d.title.size() <= 200
      && d.desc is string && d.desc.size() > 0 && d.desc.size() <= 5000
      && d.category is string
      && d.status == 'received'
      && d.anonymous is bool
      && d.email is string && d.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
      && d.timeline is list && d.timeline.size() == 1;
  }

  function isStatusOnlyUpdate(before, after) {
    // Every field except status/timeline must stay exactly as it was.
    return before.ref == after.ref
      && before.email == after.email
      && before.title == after.title
      && before.desc == after.desc
      && before.anonymous == after.anonymous
      && after.status is string
      && after.timeline is list;
  }
}
